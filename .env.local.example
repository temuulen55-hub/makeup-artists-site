# --- Google Calendar (Захиалгын систем) ---
# Google Cloud Console > Service Account-аас үүсгэнэ. Календарыг энэ
# service account-ийн email рүү "Make changes to events" эрхээр share хийнэ.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_CALENDAR_ID=primary

# --- Instagram Graph API (Бүтээлүүд хуудас) ---
# Basic Display API 2024 оны 12-р сард зогссон тул эдгээрийг ашиглана:
# Instagram Business/Creator account, Facebook Page-тэй холбосон байх шаардлагатай.
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
# Token шинэчлэхэд (60 хоног тутамд) ашиглах cron secret
CRON_SECRET=

# --- Имэйл/SMS мэдэгдэл ---
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- Төлбөр (сургалт) ---
QPAY_CLIENT_ID=
QPAY_CLIENT_SECRET=
